/* 全局样式 - 自然清新风格 */

/* 主题色变量 */
page {
  --primary-green: #4CAF50;
  --light-green: #8BC34A;
  --dark-green: #388E3C;
  --primary-blue: #2196F3;
  --light-blue: #64B5F6;
  --bg-color: #f5f7fa;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #e0e0e0;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  --shadow-light: 0 1px 4px rgba(0, 0, 0, 0.05);
}

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-green), var(--light-green));
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #ffffff;
  color: var(--primary-green);
  border: 2rpx solid var(--primary-green);
  border-radius: 48rpx;
  padding: 18rpx 46rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-secondary:active {
  background: var(--bg-color);
}

/* 输入框样式 */
.input {
  background: var(--bg-color);
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--primary-green);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary-green);
}

.tag-blue {
  background: rgba(33, 150, 243, 0.1);
  color: var(--primary-blue);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-hint);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-hint);
}

/* 图片懒加载基础样式 */
.lazy-image {
  background: var(--bg-color);
  border-radius: 12rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 滚动容器 */
.scroll-container {
  height: 100%;
  overflow-y: scroll;
}

/* 网格布局 */
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

/* Flex 工具类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 文字工具类 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-hint {
  color: var(--text-hint);
}

.text-green {
  color: var(--primary-green);
}

.text-blue {
  color: var(--primary-blue);
}

.text-bold {
  font-weight: 600;
}

.text-center {
  text-align: center;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 间距工具类 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }

.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 16rpx; }
.ml-24 { margin-left: 24rpx; }

.mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }
.mr-24 { margin-right: 24rpx; }

.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }
