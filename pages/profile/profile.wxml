<view class="container">
  <!-- 用户信息头部 -->
  <view class="profile-header card">
    <view class="user-avatar-wrapper">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
    </view>
    <view class="user-nickname">{{userInfo.nickName || '未登录'}}</view>
    <view class="user-bio text-hint" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</view>
    
    <view class="user-stats flex mt-32">
      <view class="stat-item text-center">
        <view class="stat-value text-bold">{{stats.petCount}}</view>
        <view class="stat-label text-hint">植宠</view>
      </view>
      <view class="stat-item text-center">
        <view class="stat-value text-bold">{{stats.followingCount}}</view>
        <view class="stat-label text-hint">关注</view>
      </view>
      <view class="stat-item text-center">
        <view class="stat-value text-bold">{{stats.followersCount}}</view>
        <view class="stat-label text-hint">粉丝</view>
      </view>
      <view class="stat-item text-center">
        <view class="stat-value text-bold">{{stats.postsCount}}</view>
        <view class="stat-label text-hint">动态</view>
      </view>
    </view>

    <view class="profile-actions" wx:if="{{!isMyProfile}}">
      <button class="btn-follow {{isFollowed ? 'following' : ''}}" bindtap="toggleFollow">
        {{isFollowed ? '已关注' : '+ 关注'}}
      </button>
    </view>
  </view>

  <!-- 编辑资料（仅自己可见） -->
  <view class="edit-profile card" wx:if="{{isMyProfile}}">
    <view class="edit-btn" bindtap="editProfile">
      <text>✏️ 编辑资料</text>
    </view>
  </view>

  <!-- 植宠展示 -->
  <view class="pets-section">
    <view class="section-title">我的植宠</view>
    <view class="pets-grid grid-3">
      <view class="pet-item" wx:for="{{pets}}" wx:key="_id" bindtap="goToPetDetail" data-id="{{item._id}}">
        <image class="pet-image" src="{{item.image || '/images/default-pet.png'}}" mode="aspectFill" lazy-load />
        <view class="pet-name text-ellipsis">{{item.name}}</view>
        <view class="pet-type text-hint text-ellipsis">{{getPetTypeName(item.type)}}</view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{pets.length === 0}}">
      <image src="/images/empty-pets.png" mode="aspectFit" />
      <view class="empty-text">还没有植宠</view>
    </view>
  </view>

  <!-- 动态展示 -->
  <view class="posts-section">
    <view class="section-title">他的动态</view>
    <view class="posts-list">
      <view class="post-item card" wx:for="{{posts}}" wx:key="_id" bindtap="goToPostDetail" data-id="{{item._id}}">
        <view class="post-images" wx:if="{{item.images && item.images.length > 0}}">
          <view class="image-grid image-grid-{{item.images.length > 1 ? 'multiple' : 'single'}}">
            <view class="image-item" wx:for="{{item.images}}" wx:key="*this" wx:for-item="image">
              <image src="{{image}}" mode="aspectFill" lazy-load />
            </view>
          </view>
        </view>
        <view class="post-content text-ellipsis-2" wx:if="{{item.content}}">{{item.content}}</view>
        <view class="post-footer flex-between mt-16">
          <view class="post-time text-hint">{{formatRelativeTime(item.createdAt)}}</view>
          <view class="post-likes flex">
            <text>❤️</text>
            <text class="ml-8">{{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{posts.length === 0}}">
      <image src="/images/empty-posts.png" mode="aspectFit" />
      <view class="empty-text">暂无动态</view>
    </view>
  </view>
</view>
