/* 任务表单页面样式 */

.form-card {
  padding: 32rpx;
}

.form-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid var(--primary-green);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-label.required::before {
  content: '*';
  color: #F44336;
  margin-right: 4rpx;
}

.form-tip {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 植宠选择器 */
.pet-selector {
  background: var(--bg-color);
  border-radius: 12rpx;
  padding: 24rpx;
}

.pet-info {
  align-items: center;
}

.pet-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background: var(--border-color);
}

.pet-details {
  display: flex;
  flex-direction: column;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.pet-type {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.pet-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  font-size: 28rpx;
}

/* 类型网格 */
.type-grid {
  gap: 16rpx;
}

.type-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-option.active {
  border-color: var(--primary-green);
  background: rgba(76, 175, 80, 0.05);
}

.type-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 12rpx;
}

.type-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 优先级选择 */
.priority-selector {
  display: flex;
  gap: 16rpx;
}

.priority-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.priority-option.active {
  border-width: 2rpx;
  border-style: solid;
}

.priority-option.active.low {
  border-color: #999999;
  color: #999999;
  background: rgba(153, 153, 153, 0.05);
}

.priority-option.active.medium {
  border-color: #FF9800;
  color: #FF9800;
  background: rgba(255, 152, 0, 0.05);
}

.priority-option.active.high {
  border-color: #F44336;
  color: #F44336;
  background: rgba(244, 67, 54, 0.05);
}

/* 时间选择器 */
.picker {
  padding: 20rpx 24rpx;
  background: #ffffff;
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker.placeholder {
  color: var(--text-hint);
}

/* 周期选择 */
.schedule-selector {
  display: flex;
  gap: 16rpx;
}

.schedule-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.schedule-option.active {
  border-color: var(--primary-green);
  background: rgba(76, 175, 80, 0.05);
  color: var(--primary-green);
}

/* 星期选择 */
.weekdays-selector {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.weekday-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.weekday-item.active {
  border-color: var(--primary-green);
  background: rgba(76, 175, 80, 0.1);
  color: var(--primary-green);
  font-weight: 500;
}

/* 提交按钮 */
.submit-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.btn-cancel {
  flex: 1;
  background: #ffffff;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
}

.btn-primary {
  flex: 1;
  background: linear-gradient(135deg, var(--primary-green), var(--light-green));
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}
