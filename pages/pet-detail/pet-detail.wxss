/* 植宠详情页样式 */

/* 头部信息 */
.pet-header {
  position: relative;
  overflow: hidden;
  padding: 0;
}

.pet-cover-wrapper {
  position: relative;
  height: 400rpx;
}

.pet-cover {
  width: 100%;
  height: 100%;
}

.pet-cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
}

.pet-basic-info {
  position: absolute;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  color: #ffffff;
}

.pet-name {
  font-size: 40rpx;
  font-weight: 600;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.pet-stats {
  gap: 32rpx;
}

.pet-stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.9;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 4rpx;
}

.pet-actions {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  gap: 16rpx;
}

.btn-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  padding: 0;
  border: none;
}

.btn-icon::after {
  border: none;
}

/* 描述信息 */
.pet-description {
  margin-top: 24rpx;
}

.description-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

/* 相册 */
.pet-album {
  margin-top: 24rpx;
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.album-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: var(--bg-color);
}

.album-item image {
  width: 100%;
  height: 100%;
}

/* 标签页 */
.tabs-wrapper {
  margin-top: 32rpx;
  margin-bottom: 24rpx;
}

.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 8rpx;
  box-shadow: var(--shadow-light);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--primary-green);
  color: #ffffff;
  font-weight: 500;
}

/* 时间线 */
.timeline-section {
  padding-bottom: 32rpx;
}

.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: var(--border-color);
}

.timeline-item {
  position: relative;
  margin-bottom: 32rpx;
}

.timeline-dot {
  position: absolute;
  left: -32rpx;
  top: 32rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: var(--primary-green);
  border: 4rpx solid #ffffff;
  box-shadow: 0 2px 8px rgba(76, 175, 80, 0.3);
}

.timeline-content {
  margin-left: 16rpx;
}

.timeline-date {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.post-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.post-images {
  margin-top: 16rpx;
}

.post-image {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: var(--bg-color);
}

.post-image.grid {
  width: calc(33.33% - 12rpx);
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.post-image image {
  width: 100%;
  aspect-ratio: 1;
}

.post-footer {
  border-top: 1rpx solid var(--border-color);
  padding-top: 16rpx;
  margin-top: 16rpx;
}

.post-actions {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-item {
  display: flex;
  align-items: center;
}

.action-item text:first-child {
  font-size: 32rpx;
}

.action-item text.liked {
  color: #F44336;
}

/* 任务列表 */
.add-task-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 12rpx;
  color: var(--primary-green);
  font-size: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-light);
}

.task-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.task-header {
  align-items: flex-start;
}

.task-status {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.task-status.completed {
  background: rgba(76, 175, 80, 0.2);
}

.status-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 12rpx;
  background: var(--border-color);
}

.task-status.completed .status-dot {
  background: var(--primary-green);
}

.task-info {
  flex: 1;
}

.task-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.task-title.completed {
  text-decoration: line-through;
  color: var(--text-hint);
}

.task-meta {
  font-size: 24rpx;
}

.task-action {
  margin-left: 16rpx;
}

.task-details {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.task-desc {
  font-size: 26rpx;
  line-height: 1.5;
}

.task-schedule {
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}
