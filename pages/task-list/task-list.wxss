/* 任务列表页面样式 */

.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
}

.filter-tabs {
  display: flex;
  background: var(--bg-color);
  border-radius: 32rpx;
  padding: 4rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.tab-item.active {
  background: var(--primary-green);
  color: #ffffff;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: var(--bg-color);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.sort-icon {
  font-size: 20rpx;
}

/* 统计卡片 */
.stats-card {
  margin-top: 24rpx;
}

.stats-header {
  align-items: center;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stats-date {
  font-size: 24rpx;
}

.stats-grid {
  gap: 16rpx;
}

.stats-item {
  padding: 16rpx 0;
  background: var(--bg-color);
  border-radius: 12rpx;
}

.stats-value {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
}

/* 任务卡片 */
.task-card {
  position: relative;
  padding: 24rpx;
  margin-top: 24rpx;
  overflow: hidden;
}

.task-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(76, 175, 80, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.task-icon-wrapper.completed {
  background: rgba(76, 175, 80, 0.3);
}

.task-icon {
  width: 40rpx;
  height: 40rpx;
}

.task-info {
  flex: 1;
}

.task-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  transition: all 0.3s;
}

.task-title.completed {
  text-decoration: line-through;
  color: var(--text-hint);
}

.task-meta {
  font-size: 24rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.task-details {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.task-desc {
  font-size: 26rpx;
  line-height: 1.5;
}

.task-footer {
  align-items: center;
}

.task-time {
  font-size: 24rpx;
}

.task-actions {
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 16rpx;
  font-size: 28rpx;
}

/* 完成标记 */
.completed-badge {
  position: absolute;
  top: 16rpx;
  right: -60rpx;
  background: var(--primary-green);
  color: #ffffff;
  padding: 8rpx 80rpx;
  font-size: 22rpx;
  transform: rotate(45deg);
  opacity: 0.8;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 浮动按钮 */
.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 32rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, var(--primary-green), var(--light-green));
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  box-shadow: 0 4px 16px rgba(76, 175, 80, 0.4);
  z-index: 999;
}

.fab-btn:active {
  transform: scale(0.95);
}
