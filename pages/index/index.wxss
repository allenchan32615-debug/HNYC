/* 公园广场页面样式 */

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-color);
  border-radius: 32rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-placeholder {
  font-size: 28rpx;
  color: var(--text-hint);
}

.publish-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, var(--primary-green), var(--light-green));
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 分类滚动 */
.category-scroll {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid var(--border-color);
}

.category-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  border-radius: 24rpx;
  transition: all 0.3s;
}

.category-item.active {
  background: var(--primary-green);
  color: #ffffff;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid var(--border-color);
}

.sort-tabs {
  display: flex;
  gap: 32rpx;
}

.sort-item {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
  position: relative;
}

.sort-item.active {
  color: var(--primary-green);
  font-weight: 500;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: var(--primary-green);
  border-radius: 2rpx;
}

.refresh-btn {
  padding: 8rpx 16rpx;
  font-size: 32rpx;
}

/* 动态列表 */
.posts-scroll {
  height: 100vh;
}

.posts-list {
  padding: 24rpx;
}

.post-card {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.post-header {
  align-items: center;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 16rpx;
  background: var(--bg-color);
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  color: var(--text-primary);
}

.post-time {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.follow-btn {
  padding: 12rpx 24rpx;
  background: var(--bg-color);
  color: var(--primary-green);
  border-radius: 24rpx;
  font-size: 26rpx;
  border: 2rpx solid var(--primary-green);
}

.follow-btn:active {
  background: var(--primary-green);
  color: #ffffff;
}

/* 关联植宠 */
.post-pet {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.pet-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  background: var(--border-color);
}

.pet-info {
  flex: 1;
}

.pet-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.pet-type {
  font-size: 24rpx;
  margin-top: 4rpx;
}

/* 内容 */
.post-content-wrapper {
  margin-bottom: 16rpx;
}

.post-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 图片网格 */
.post-images {
  margin-top: 16rpx;
}

.image-grid {
  display: grid;
  gap: 12rpx;
}

.image-grid-single {
  grid-template-columns: 1fr;
}

.image-grid-multiple {
  grid-template-columns: repeat(3, 1fr);
}

.image-item {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: var(--bg-color);
}

.image-grid-single .image-item {
  max-height: 600rpx;
  aspect-ratio: auto;
}

.image-item image {
  width: 100%;
  height: 100%;
}

/* 底部互动 */
.post-footer {
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.post-actions {
  gap: 32rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.action-icon {
  font-size: 32rpx;
}

.action-count {
  font-size: 24rpx;
}

.action-item.liked {
  color: #F44336;
}

.post-type-tag {
  padding: 8rpx 16rpx;
  background: var(--bg-color);
  color: var(--text-secondary);
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 评论区 */
.comments-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.comments-divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 16rpx 0;
}

.comment-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.comment-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  margin-right: 16rpx;
  background: var(--bg-color);
}

.comment-content {
  flex: 1;
}

.comment-user {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.comment-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.comment-time {
  font-size: 22rpx;
}

.view-more-comments {
  padding: 12rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: var(--primary-green);
}

/* 加载更多 */
.load-more {
  padding: 32rpx;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-hint);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-hint);
}
