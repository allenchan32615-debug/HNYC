/* 发布动态页面样式 */

.form-card {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.form-tip {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 植宠选择器 */
.pet-selector {
  background: var(--bg-color);
  border-radius: 12rpx;
  padding: 24rpx;
}

.pet-info {
  align-items: center;
}

.pet-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background: var(--border-color);
}

.pet-details {
  display: flex;
  flex-direction: column;
}

.pet-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.pet-type {
  font-size: 24rpx;
  margin-top: 4rpx;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.pet-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  font-size: 28rpx;
}

/* 内容输入框 */
.content-textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* 图片网格 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: var(--bg-color);
}

.image-item image {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
}

.image-add-btn {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  border: 2rpx dashed var(--border-color);
  background: var(--bg-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 类型选择 */
.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-option.active {
  border-color: var(--primary-green);
  background: rgba(76, 175, 80, 0.05);
}

.type-option text:first-child {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.type-option text:last-child {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 位置选择 */
.location-selector {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--bg-color);
  border-radius: 12rpx;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.location-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 提交按钮 */
.submit-btn {
  margin-top: 48rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-green), var(--light-green));
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}
